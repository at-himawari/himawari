# Environment Variables Example
# Copy this file to .env.local and modify as needed

# Development Settings
# Show test posts in development environment (posts with 'test-' prefix)
# Set to 'true' to display test posts, leave empty or set to 'false' to hide them
SHOW_TEST_POSTS=false

# Blog engagement API
# API Gateway HTTP API base URL for likes and comments
NEXT_PUBLIC_ENGAGEMENT_API_URL=

# Other environment variables can be added here as needed

# Strapi API
# Dev Container uses http://strapi:1337 for container-to-container access.
# Local macOS development can use http://localhost:1337 when Strapi is exposed.
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
VITE_STRAPI_URL=http://localhost:1337
